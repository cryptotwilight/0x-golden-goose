# ── Wallet ─────────────────────────────────────────────────────────────────────
# Private key for the executor agent (Sepolia testnet only — never use mainnet funds)
PRIVATE_KEY=0x...

# ── RPC Endpoints ──────────────────────────────────────────────────────────────
# Mainnet (read-only price feeds)
MAINNET_RPC_URL=https://1rpc.io/eth
# Sepolia (trade execution)
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# ── 0G Labs Storage ─────────────────────────────────────────────────────────────
# 0G testnet indexer for decentralized agent state
OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# ── Gensyn AXL ─────────────────────────────────────────────────────────────────
# AXL node HTTP API (localhost after running: ./axl-node -config node-config.json)
AXL_API_URL=http://127.0.0.1:9002

# ── KeeperHub ───────────────────────────────────────────────────────────────────
# Get your API key at https://keeperhub.com/dashboard
KEEPERHUB_API_KEY=kh...
KEEPERHUB_API_URL=https://api.keeperhub.com

# ── ENS ────────────────────────────────────────────────────────────────────────
# ENS names for agent identities (optional — for display/logging only)
ENS_SCOUT_NAME=scout.tradeclaw.eth
ENS_RISK_NAME=risk.tradeclaw.eth
ENS_EXECUTOR_NAME=executor.tradeclaw.eth

# ── Trading Parameters ─────────────────────────────────────────────────────────
# Token pair to monitor (Uniswap v3)
TOKEN_IN=WETH
TOKEN_OUT=USDC
# Pool fee tier in bps: 500 = 0.05%, 3000 = 0.3%, 10000 = 1%
POOL_FEE=500
# Amount in (wei) per trade signal
TRADE_AMOUNT_WEI=100000000000000000
# Price deviation % that triggers a BUY signal
BUY_THRESHOLD_PCT=1.5
# Price deviation % that triggers a SELL signal
SELL_THRESHOLD_PCT=1.5
# Max slippage tolerance (%)
MAX_SLIPPAGE_PCT=0.5

# ── Polling ─────────────────────────────────────────────────────────────────────
SCOUT_POLL_MS=15000
